# Backend environment variables (example)
# Copy to .env and fill in real values for local development.

APP_NAME="LLM Forge"
APP_VERSION="0.1.0"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

HOST=0.0.0.0
PORT=8000
WORKERS=1

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=true

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=llmforge
POSTGRES_PASSWORD=llmforge
POSTGRES_DB=llmforge

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_DATASETS=datasets
MINIO_BUCKET_ARTIFACTS=artifacts

MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=s3://artifacts/mlflow
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

LOG_LEVEL=INFO
LOG_FORMAT=json

# JWT / Authentication (Phase 1)
# IMPORTANT: replace JWT_SECRET_KEY with a strong random value in production.
JWT_SECRET_KEY=change-me-in-production-this-is-a-development-only-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ISSUER=llm-forge
JWT_AUDIENCE=llm-forge-api

# Password policy (Phase 1)
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

# Bcrypt cost factor (Phase 1)
BCRYPT_ROUNDS=12
